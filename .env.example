# Innovation Game Environment Variables

# Backend Configuration
# =====================

# Debug mode - enables verbose logging
INNOVATION_DEBUG=false

# Environment type (development, staging, production)
# Setting this to "production" will enforce strict security checks
INNOVATION_ENV=development

# JWT Authentication (CRITICAL FOR SECURITY!)
# JWT algorithm (HS256, RS256, etc.)
JWT_ALGORITHM=HS256

# JWT token expiration in hours
JWT_EXPIRATION_HOURS=24
# --------------------------------------------
# ⚠️  SECURITY WARNING: You MUST change this in production! ⚠️
# The default key is publicly known and provides NO security.
#
# To generate a secure key, run:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Then set it below (remove the default value):
JWT_SECRET_KEY=your-secret-key-change-this-in-production

# CORS Configuration
# ------------------
# Comma-separated list of allowed origins for CORS
# Default: "http://localhost:3000,http://localhost:3001"
# Production example: "https://innovation.example.com,https://www.innovation.example.com"
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Allow all origins (use only in development, not recommended for production)
# Set to "true" to allow all origins (overrides CORS_ORIGINS)
CORS_ALLOW_ALL=false

# Frontend Configuration
# ======================
# These are used when building the React app

# API base URL (for REST endpoints)
# Default: http://localhost:8000
REACT_APP_API_BASE=http://localhost:8000

# WebSocket base URL
# Default: ws://localhost:8000
REACT_APP_WS_BASE=ws://localhost:8000

# Frontend Logging Configuration
# -------------------------------
# Enable debug logging (true/false)
# Default: false in production, true in development
REACT_APP_DEBUG=false

# Log level (DEBUG, INFO, WARN, ERROR, NONE)
# Default: WARN in production, INFO in development
REACT_APP_LOG_LEVEL=INFO

# Redis Configuration (Optional - falls back to in-memory storage)
# ================================================================
# Redis is used for game state persistence and scaling to multiple instances.
# If not configured or unavailable, the application will use in-memory storage.

# Basic Redis connection (required)
# ---------------------------------
# Local development (default):
REDIS_URL=redis://localhost:6379/0

# Production examples:
# Redis with password: redis://:password@redis.example.com:6379/0
# Redis with username: redis://username:password@redis.example.com:6379/0
# Redis with SSL: rediss://username:password@redis.example.com:6380/0

# SSL/TLS Configuration for Redis (production recommended)
# --------------------------------------------------------
# Enable SSL/TLS for Redis connections (true/false)
# Use "true" for production, cloud Redis services, or secure networks
REDIS_SSL=false

# SSL certificate verification level (none, optional, required)
# - none: No certificate verification (not recommended)
# - optional: Verify if certificate is provided
# - required: Always verify certificate (recommended for production)
REDIS_SSL_CERT_REQS=required

# SSL certificate files (optional - for client certificate authentication)
# REDIS_SSL_CA_CERTS=/path/to/ca-cert.pem
# REDIS_SSL_CERTFILE=/path/to/client-cert.pem
# REDIS_SSL_KEYFILE=/path/to/client-key.pem

# Redis Authentication (production recommended)
# ---------------------------------------------
# Redis password (if required by your Redis instance)
# REDIS_PASSWORD=your-redis-password

# Redis username (for Redis 6+ ACL authentication)
# REDIS_USERNAME=your-redis-username

# Redis database number (0-15, default is 0)
REDIS_DB=0

# Connection Pool Configuration (performance tuning)
# --------------------------------------------------
# Maximum number of connections in the pool
REDIS_MAX_CONNECTIONS=20

# Socket timeout in seconds
REDIS_SOCKET_TIMEOUT=5.0

# Connection timeout in seconds
REDIS_SOCKET_CONNECT_TIMEOUT=5.0

# Retry on timeout (true/false)
REDIS_RETRY_ON_TIMEOUT=true

# Health check interval in seconds
REDIS_HEALTH_CHECK_INTERVAL=30

# =============================================
# SERVER CONFIGURATION
# =============================================
# Server host and port (for uvicorn)
# Host to bind to (0.0.0.0 = all interfaces)
# AI services will automatically use localhost for internal API calls
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# =============================================
# GAME ENGINE CONFIGURATION
# =============================================
# Game cleanup and timeout settings (in seconds)
GAME_CLEANUP_INTERVAL=60
STALE_CONNECTION_TIMEOUT=300
GAME_TIMEOUT=1800

# Game limits
MAX_GAMES_PER_SERVER=100
MAX_PLAYERS_PER_GAME=4

# Expansion Configuration
# -----------------------
# Enable Figures expansion cards (130 additional cards, ages 0-11)
# WARNING: Figures expansion is in development and contains TODO primitives
# Only enable for testing/development purposes
# Default: false (disabled for production safety)
FIGURES_EXPANSION_ENABLED=false

# WebSocket settings
WS_PING_INTERVAL=20
WS_PING_TIMEOUT=30
MAX_MESSAGE_SIZE=1048576

# Test mode settings
TEST_MODE=false
AUTO_ADVANCE_TESTS=false

# =============================================
# LOGGING CONFIGURATION
# =============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log format (Python logging format string)
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# JSON logging (for structured logging systems)
JSON_LOGGING=false

# Optional file logging
# LOG_FILE=/var/log/innovation.log
# MAX_LOG_FILE_SIZE=10485760
# LOG_BACKUP_COUNT=5

# =============================================
# TEST CONFIGURATION
# =============================================
# Base URLs for integration tests
TEST_API_BASE=http://localhost:8000
TEST_WS_BASE=ws://localhost:8000
TEST_FRONTEND_BASE=http://localhost:3000

# Test timeouts
TEST_TIMEOUT=30
TEST_API_TIMEOUT=10
TEST_WS_TIMEOUT=15

# Test limits
TEST_GAME_TIMEOUT=120
MAX_TEST_GAMES=10

# =============================================
# AI PLAYER CONFIGURATION
# =============================================
# AI player service using Claude API
# Requires Anthropic API key from https://console.anthropic.com/

# Enable AI players (true/false)
AI_ENABLED=true

# Anthropic API key (required for AI players)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Cost limits (in USD)
AI_DAILY_COST_LIMIT=50.00
AI_MAX_COST_PER_GAME=5.00

# Model configuration by difficulty
# Beginner/Intermediate use Haiku (fast, cheap)
# Advanced uses Sonnet 4.5 (balanced)
# Expert uses Opus 4 (best, expensive)
AI_BEGINNER_MODEL=claude-3-5-haiku-20241022
AI_INTERMEDIATE_MODEL=claude-3-5-haiku-20241022
AI_ADVANCED_MODEL=claude-sonnet-4-5-20250929
AI_EXPERT_MODEL=claude-opus-4-1-20250122

# Think time (milliseconds) - simulates realistic decision time
AI_BEGINNER_THINK_TIME_MS=500
AI_INTERMEDIATE_THINK_TIME_MS=1000
AI_ADVANCED_THINK_TIME_MS=1500
AI_EXPERT_THINK_TIME_MS=2000

# Max output tokens by difficulty
AI_BEGINNER_MAX_TOKENS=500
AI_INTERMEDIATE_MAX_TOKENS=800
AI_ADVANCED_MAX_TOKENS=1000
AI_EXPERT_MAX_TOKENS=1500

# =============================================
# ADDITIONAL CONFIGURATION NOTES
# =============================================
# This file now supports comprehensive configuration through the new
# centralized app_config.py system. All values are validated on startup.
#
# =============================================
# PRODUCTION SECURITY HARDENING
# =============================================
# Rate limiting configuration
# IMPORTANT: Keep enabled in production to prevent DoS attacks
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST_SIZE=10

# Request size limits (in bytes)
MAX_REQUEST_SIZE=1048576

# Development endpoints (DISABLE in production)
ENABLE_DEV_ENDPOINTS=false

# Session security
SESSION_TIMEOUT_MINUTES=60
SECURE_COOKIES=false

# Logging security
LOG_REQUESTS=false
LOG_RESPONSES=false

# Additional security headers
SECURITY_HEADERS_ENABLED=true

# Content Security Policy
CSP_ENABLED=true
CSP_REPORT_URI=/csp-report

# =============================================
# PRODUCTION SECURITY CHECKLIST
# =============================================
# Before deploying to production:
#
# ✅ Set INNOVATION_ENV=production
# ✅ Set JWT_SECRET_KEY to cryptographically secure key
# ✅ Set CORS_ALLOW_ALL=false and configure CORS_ORIGINS
# ✅ Set INNOVATION_DEBUG=false
# ✅ Set RATE_LIMIT_ENABLED=true
# ✅ Set ENABLE_DEV_ENDPOINTS=false
# ✅ Set SECURE_COOKIES=true for HTTPS
# ✅ Set LOG_REQUESTS=false and LOG_RESPONSES=false
# ✅ Configure SESSION_TIMEOUT_MINUTES appropriately
# ✅ Set MAX_REQUEST_SIZE to reasonable limit
# ✅ Use HTTPS URLs for all API and WebSocket endpoints
# ✅ Enable Redis SSL if using Redis
# ✅ Set restrictive log file permissions (600/640)
#
# For a complete configuration summary, run:
#   python -c "from app_config import get_config_summary; print(get_config_summary())"
#
# For security validation, run:
#   python -c "from security_config import validate_security_on_startup; print(validate_security_on_startup())"

# =============================================
# AI PLAYER CONFIGURATION
# =============================================
# Enable AI players (requires Anthropic API key)
AI_ENABLED=true

# Anthropic API key (get from https://console.anthropic.com/)
# IMPORTANT: Keep this secret! Never commit to version control.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# AI Model Configuration
# ----------------------
# Configure which Claude models to use for each difficulty level.
# Development recommendation: Use Haiku for cost savings, enable Sonnet for intermediate+

# Beginner AI - Random legal moves, learning the game
# Cost: ~$0.05-0.15 per game
AI_BEGINNER_MODEL=claude-3-5-haiku-20241022

# Intermediate AI - Tactical play with basic strategy
# Cost: ~$0.10-0.30 per game (Haiku) or ~$0.30-0.60 (Sonnet)
# Development: Use Sonnet for better play quality
AI_INTERMEDIATE_MODEL=claude-sonnet-4-5-20250929

# Advanced AI - Strategic planning and combos
# Cost: ~$0.45-0.90 per game
# Development: Consider leaving commented to save costs
# AI_ADVANCED_MODEL=claude-sonnet-4-5-20250929

# Expert AI - Near-optimal play with deep analysis
# Cost: ~$2.25-4.50 per game
# Development: Recommend leaving commented (very expensive)
# AI_EXPERT_MODEL=claude-opus-4-1-20250122

# AI Cost Limits
# --------------
# Daily spending cap across all AI players
AI_DAILY_COST_LIMIT=50.00

# Per-game spending cap (prevents runaway costs)
AI_MAX_COST_PER_GAME=5.00

# AI Behavior Tuning
# ------------------
# Think time in milliseconds (adds realism, 0 to disable)
AI_BEGINNER_THINK_TIME_MS=500
AI_INTERMEDIATE_THINK_TIME_MS=1000
AI_ADVANCED_THINK_TIME_MS=1500
AI_EXPERT_THINK_TIME_MS=2000

# Max tokens per API call
AI_BEGINNER_MAX_TOKENS=500
AI_INTERMEDIATE_MAX_TOKENS=800
AI_ADVANCED_MAX_TOKENS=1000
AI_EXPERT_MAX_TOKENS=1500
